{
  "name": "saudi-municipal-coding",
  "version": "1.0.0",
  "description": "Open dataset of Saudi Arabia's regions, cities, and districts from the MOMRAH Unified Municipal Coding — bilingual lookups with stable IDs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./data/*": "./data/*"
  },
  "files": ["dist", "data", "README.md"],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "saudi",
    "saudi-arabia",
    "regions",
    "cities",
    "districts",
    "municipal",
    "momrah",
    "lookup"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yasseralsamman/saudi-municipal-coding.git",
    "directory": "packages/js"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.5",
    "vitest": "^2"
  }
}
