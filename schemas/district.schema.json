{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yasseralsamman/saudi-municipal-coding/schemas/district.schema.json",
  "title": "District",
  "description": "One district of Saudi Arabia, linked to its city and region.",
  "type": "object",
  "additionalProperties": false,
  "required": ["district_id", "city_id", "region_id", "name_ar", "name_en"],
  "properties": {
    "district_id": { "type": "integer", "minimum": 1 },
    "city_id": { "type": "integer", "minimum": 1 },
    "region_id": { "type": "integer", "minimum": 1, "maximum": 13 },
    "name_ar": { "type": "string", "minLength": 1 },
    "name_en": { "type": "string", "minLength": 1 }
  }
}
